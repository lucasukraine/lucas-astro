---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  lang="en"
  title="Documents — transparency reports and financial statements | LUCAS"
  description="Documents published in accordance with the requirements of the Law of Ukraine 'On Audit of Financial Statements and Auditing Activities'. Transparency reports and financial statements of LUCAS."
>
  <main>

    <section class="doc-hero">
      <div class="doc-hero-deco" aria-hidden="true"></div>
      <div class="doc-hero-inner">
        <div class="doc-hero-eyebrow">Transparency</div>
        <h1>Documents</h1>
        <p class="doc-hero-sub">published in accordance with the requirements of the Law of Ukraine "On Audit of Financial Statements and Auditing Activities"</p>
      </div>
    </section>

    <section class="doc-section">
      <div class="doc-table">

        <div class="doc-row">
          <div class="doc-year">2019</div>
          <div class="doc-name">Transparency Report 2019</div>
          <a class="doc-dl" href={base + '/documents/Transparency_2019.pdf'} download aria-label="Download Transparency Report 2019">
            <span class="doc-dl-label">PDF</span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7 1v8M4 7l3 3 3-3M2 12h10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <div class="doc-row">
          <div class="doc-year"></div>
          <div class="doc-name">Transparency Report 2019 (amended)</div>
          <a class="doc-dl" href={base + '/documents/Transparency_2019A.pdf'} download aria-label="Download Transparency Report 2019 (amended)">
            <span class="doc-dl-label">PDF</span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7 1v8M4 7l3 3 3-3M2 12h10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
