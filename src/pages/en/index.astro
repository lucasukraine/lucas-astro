---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Concept from '../../components/Concept.astro';
import Solutions from '../../components/Solutions.astro';
import Industries from '../../components/Industries.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import Contact from '../../components/Contact.astro';
import { homeFaq } from '../../data/en/homeFaq';
---

<BaseLayout
  lang="en"
  title="LUCAS — Audit-led SAF-T and Odoo Solutions in Ukraine"
  description="Financial statement audit, SAF-T Connector, Odoo migration and transfer pricing for businesses in Ukraine. LUCAS — audit and technology company for CFO."
>
  <main id="top">
    <Hero lang="en" />
    <Concept lang="en" />
    <Solutions lang="en" />
    <Industries lang="en" />
    <Contact lang="en" />
    <FaqAccordion
      eyebrow="FAQ"
      title="Frequently asked questions"
      items={homeFaq}
    />
  </main>
</BaseLayout>
