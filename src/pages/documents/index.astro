---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Документи — звіти про прозорість та фінансова звітність | LUCAS"
  description="Звіти про прозорість та фінансова звітність LUCAS, що публікуються за вимогами Закону України «Про аудит фінансової звітності та аудиторську діяльність»."
>
  <main>

    <section class="doc-hero">
      <div class="doc-hero-deco" aria-hidden="true"></div>
      <div class="doc-hero-inner">
        <div class="doc-hero-eyebrow">Прозорість</div>
        <h1>Документи</h1>
        <p class="doc-hero-sub">що публікуються відповідно до вимог Закону України «Про аудит фінансової звітності та аудиторську діяльність»</p>
      </div>
    </section>

    <section class="doc-section">
      <div class="doc-table">

        <div class="doc-row">
          <div class="doc-year">2019</div>
          <div class="doc-name">Звіт про прозорість за 2019 рік</div>
          <a class="doc-dl" href={base + '/documents/Transparency_2019.pdf'} download aria-label="Завантажити Звіт про прозорість за 2019 рік">
            <span class="doc-dl-label">PDF</span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7 1v8M4 7l3 3 3-3M2 12h10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <div class="doc-row">
          <div class="doc-year"></div>
          <div class="doc-name">Звіт про прозорість за 2019 рік (змінений)</div>
          <a class="doc-dl" href={base + '/documents/Transparency_2019A.pdf'} download aria-label="Завантажити Звіт про прозорість за 2019 рік (змінений)">
            <span class="doc-dl-label">PDF</span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7 1v8M4 7l3 3 3-3M2 12h10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
