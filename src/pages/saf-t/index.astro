---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import ServiceAeo from '../../components/ServiceAeo.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import ServiceCTA from '../../components/ServiceCTA.astro';
import ServiceBlogBlock from '../../components/ServiceBlogBlock.astro';
import { saftFaq } from '../../data/saftFaq';
const base = import.meta.env.BASE_URL;
---

<ServiceLayout
  title="Рішення для SAF-T UA — SAF-T Connector з будь-якої ERP | LUCAS"
  description="SAF-T Connector від LUCAS — ERP-незалежне рішення для підготовки XML-файлів SAF-T UA з SAP, BAS/1C, Odoo, Microsoft Dynamics і кастомних систем. On-premise, XSD-валідація, впровадження під ключ."
>
  <ServiceHero
    eyebrow="Послуга 02"
    title="SAF-T Connector"
    lead="SAF-T Connector — ERP-незалежне рішення для підготовки файлів SAF-T UA з SAP, BAS/1C, Odoo, Microsoft Dynamics, кастомних систем або кількох джерел даних одночасно. Встановлюється on-premise та впроваджується під ключ командою LUCAS."
    accent="cyan"
  />

  <ServiceAeo
    title="Коротко про SAF-T Connector від LUCAS"
    lead="SAF-T Connector — ERP-незалежне рішення для підготовки XML-файлів SAF-T UA з будь-якої облікової системи: SAP, BAS/1C, Odoo, Microsoft Dynamics, кастомних ERP або кількох джерел даних одночасно. Встановлюється on-premise, включає XSD-валідацію та логічні перевірки, впроваджується під ключ командою LUCAS. Підходить для великих платників податків, які зобов'язані або очікують необхідність подавати SAF-T UA на запит ДПС."
    rows={[
      { label: 'Що таке',          value: 'SAF-T Connector — власний продукт LUCAS для підготовки XML-файлів SAF-T UA' },
      { label: 'Що робить',        value: 'Витягує облікові дані з ERP, формує XML-файл SAF-T UA, виконує XSD-валідацію та логічні перевірки даних' },
      { label: 'Для кого',         value: 'Великі платники податків, компанії з SAP, BAS/1C, Odoo, Microsoft Dynamics або кількома джерелами даних' },
      { label: 'Чим відрізняється',value: 'ERP-незалежне on-premise рішення, власна розробка LUCAS, єдина зона відповідальності за продукт і впровадження' },
      { label: 'Результат',        value: 'XML-файл SAF-T UA, готовий до подання на запит ДПС' },
    ]}
  />

  <section class="sp-statement">
    <div class="sp-statement-inner">
      <p>SAF-T Connector не залежить від вашої ERP або облікової системи.</p>
      <div class="sp-statement-note">SAF-T Connector — окремий продукт, не вбудований у жодну ERP-систему. Впроваджуємо самостійно: клієнт надає доступ до даних, далі LUCAS працює автономно — без створення великої внутрішньої проєктної команди з боку клієнта.</div>
    </div>
  </section>

  <section class="sp-blocks">
    <div class="sp-blocks-inner">

      <div class="sp-block">
        <div>
          <div class="sp-block-label cyan">ERP-незалежність</div>
          <h2 class="sp-block-h2">Підключається до будь-яких джерел даних</h2>
        </div>
        <div class="sp-block-body">
          <p>На відміну від рішень, прив'язаних до однієї ERP, SAF-T Connector підключається до SAP, 1С/BAS, Odoo, Microsoft Dynamics та будь-яких кастомних систем. Рішення може працювати з кількома джерелами даних одночасно.</p>
          <p>Конкуруючі рішення зазвичай вбудовані всередину конкретної облікової системи — і працюють лише з нею. SAF-T Connector — окремий продукт, який не залежить від того, де саме ви ведете облік.</p>
          <ul class="sp-block-list cyan">
            <li>SAP, 1С/BAS, Odoo, Microsoft Dynamics</li>
            <li>Будь-які кастомні системи</li>
            <li>Робота з кількома джерелами даних одночасно</li>
            <li>Підключення через бази даних, API або файли експорту</li>
          </ul>
        </div>
      </div>

      <div class="sp-block">
        <div>
          <div class="sp-block-label cyan">ERP-незалежність · Коли потрібне</div>
          <h2 class="sp-block-h2">Коли ERP-незалежне рішення особливо потрібне</h2>
        </div>
        <div class="sp-block-body">
          <p>ERP-незалежне рішення для SAF-T UA особливо корисне, якщо:</p>
          <ul class="sp-block-list cyan">
            <li>облік ведеться у SAP/MS Dynamics/Oracle, але частина даних зберігається в BAS/1C, Excel, CRM, білінгу або кастомних системах;</li>
            <li>компанія змінювала ERP протягом періоду, за який може знадобитися SAF-T UA, або планує перехід на нову ERP;</li>
            <li>в ERP немає всіх полів, потрібних для структури SAF-T UA;</li>
            <li>у компанії велика кількість транзакційних даних, які повільно обробляються всередині облікової системи;</li>
            <li>стандартний ERP-модуль не покриває складний мапінг, історичні дані або специфіку українського обліку;</li>
            <li>потрібно зберігати рішення повністю в інфраструктурі компанії.</li>
          </ul>
        </div>
      </div>

      <div class="sp-block">
        <div>
          <div class="sp-block-label cyan">Продуктивність · Python</div>
          <h2 class="sp-block-h2">Швидко обробляє великі дані</h2>
        </div>
        <div class="sp-block-body">
          <p>Алгоритм SAF-T Connector написаний на Python і оптимізований для обробки великих масивів транзакційних даних. Для компаній з великими обсягами операцій це означає швидше формування SAF-T UA XML, менше навантаження на облікову систему та стабільнішу роботу з історичними періодами.</p>
          <ul class="sp-block-list cyan">
            <li>Оптимізований алгоритм на Python</li>
            <li>Обробка без навантаження на ERP клієнта</li>
            <li>Стабільна робота з великими історичними періодами</li>
          </ul>
        </div>
      </div>

      <div class="sp-block">
        <div>
          <div class="sp-block-label cyan">Валідація</div>
          <h2 class="sp-block-h2">Серія перевірок даних перед поданням</h2>
        </div>
        <div class="sp-block-body">
          <p>Автоматична XSD-валідація та додаткові шари перевірок допомагають виявити помилки до подання файлу SAF-T UA. Помилки супроводжуються описом, зрозумілим для фінансових, податкових та облікових команд.</p>
          <p>Результат — XML-файл SAF-T UA, сформований відповідно до чинної структури та технічних вимог ДПС, із попередньою валідацією даних.</p>
          <ul class="sp-block-list cyan">
            <li>Автоматична валідація XSD</li>
            <li>Додаткові шари перевірок даних</li>
            <li>Опис помилок зрозумілою для бізнес-команд мовою</li>
            <li>XML-файл SAF-T UA за вимогами ДПС</li>
          </ul>
        </div>
      </div>

      <div class="sp-block">
        <div>
          <div class="sp-block-label cyan">On-premise · Безпека</div>
          <h2 class="sp-block-h2">Дані залишаються в інфраструктурі клієнта</h2>
        </div>
        <div class="sp-block-body">
          <p>Система встановлюється на сервері клієнта. Працює без хмарного завантаження даних і без передавання облікової інформації третім сторонам. Рішення не потребує доступу в інтернет.</p>
          <ul class="sp-block-list cyan">
            <li>Встановлення на сервері клієнта</li>
            <li>Без хмарних завантажень даних</li>
            <li>Не потребує доступу в інтернет для роботи</li>
            <li>Ваші дані не виходять за межі вашої інфраструктури</li>
          </ul>
        </div>
      </div>

      <div class="sp-block">
        <div>
          <div class="sp-block-label cyan">Turnkey · 3–4 місяці</div>
          <h2 class="sp-block-h2">Впровадження не стає проєктом клієнта</h2>
        </div>
        <div class="sp-block-body">
          <p>З боку клієнта достатньо доступу до даних та надання інформації за точковими питаннями. Основне проєктне навантаження бере на себе LUCAS. Типовий строк впровадження — 3–4 місяці, залежно від кількості джерел даних, якості облікової інформації та складності мапінгу.</p>
          <ul class="sp-block-list cyan">
            <li>Клієнт надає доступ до даних і, за необхідності, пояснення облікової логіки.</li>
            <li>LUCAS впроваджує автономно</li>
            <li>Без необхідності формувати проєктні команди з боку клієнта</li>
            <li>Готовий продукт за 3–4 місяці</li>
          </ul>
        </div>
      </div>

      <div class="sp-block">
        <div>
          <div class="sp-block-label cyan">Єдина зона відповідальності</div>
          <h2 class="sp-block-h2">Один партнер, який відповідає за весь результат</h2>
        </div>
        <div class="sp-block-body">
          <p>Коли продукт постачає один підрядник, а впроваджує інший, відповідальність часто розмивається. LUCAS забезпечує єдину точку відповідальності за продукт, впровадження, методологію та підтримку.</p>
          <ul class="sp-block-list cyan">
            <li>Один партнер за продукт і впровадження</li>
            <li>Чітка зона відповідальності</li>
            <li>Конкурентна повна вартість володіння</li>
          </ul>
        </div>
      </div>

    </div>
  </section>

  <FaqAccordion
    eyebrow="Часті запитання"
    title="Що варто знати"
    items={saftFaq}
  />

  <ServiceCTA
    title="Готові обговорити впровадження SAF-T"
    titlePunct="?"
    text="Розкажіть, у яких системах зберігаються ваші облікові дані — ми оцінимо обсяг робіт, складність мапінгу і запропонуємо умови впровадження SAF-T Connector під ключ."
    href={base + '/#contact'}
    linkText="Залишити запит"
  />

  <ServiceBlogBlock
    service="saft"
    title="Блог про SAF-T в Україні"
    subtitle="Пояснюємо, хто має подавати SAF-T UA на запит ДПС, як підготувати дані, пройти XSD-валідацію та оцінити готовність компанії."
    moreHref={base + '/blog/'}
  />

</ServiceLayout>
