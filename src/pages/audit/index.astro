---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import ServiceCTA from '../../components/ServiceCTA.astro';
import ServiceBlogBlock from '../../components/ServiceBlogBlock.astro';
import { auditFaq } from '../../data/auditFaq';
const base = import.meta.env.BASE_URL;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "AccountingService",
      "@id": "https://lucasua.com/audit/",
      "name": "LUCAS",
      "url": "https://lucasua.com/audit/",
      "description": "LUCAS — аудиторська фірма в Україні, що надає послуги аудиту фінансової звітності, обов'язкового аудиту, аудиту за МСА, аудиту МСФЗ-звітності, групового аудиту, огляду звітності та погоджених процедур.",
      "areaServed": "Ukraine",
      "serviceType": [
        "Аудит фінансової звітності",
        "Обов'язковий аудит",
        "Аудит за МСА",
        "Аудит фінансової звітності за МСФЗ",
        "Груповий аудит",
        "Огляд фінансової звітності",
        "Погоджені процедури"
      ],
      "telephone": "+380443447915",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "пл. Спортивна 1а, БЦ Гулівер, Вежа А, 17 поверх",
        "addressLocality": "Київ",
        "postalCode": "01601",
        "addressCountry": "UA"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": auditFaq.map(item => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer
        }
      }))
    }
  ]
});
---

<ServiceLayout
  title="Аудиторська фірма LUCAS — аудит фінансової звітності в Україні"
  description="LUCAS — аудиторська фірма в Україні. Проводимо обов'язковий аудит, аудит фінансової звітності відповідно до МСА, аудит фінансової звітності за МСФЗ, груповий аудит, огляд звітності та погоджені процедури."
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={jsonLd}></script>
  </Fragment>

  <ServiceHero
    eyebrow="Послуга 01"
    title="Аудиторська фірма: аудит фінансової звітності в Україні"
    breadcrumb="Аудит"
    lead="LUCAS — українська аудиторська фірма, що проводить аудит фінансової звітності за Міжнародними стандартами аудиту, обов'язковий аудит, груповий аудит та завдання з надання впевненості. Підготовка фінансової звітності за МСФЗ не надається одночасно з аудитом тієї самої звітності для одного клієнта — відповідно до вимог незалежності аудитора та професійної етики."
  />

  <!-- AEO/GEO block: визначення LUCAS для AI Overviews та featured snippets -->
  <section class="sp-aeo">
    <div class="sp-aeo-inner">
      <h2 class="sp-aeo-h2">Коротко про аудиторську фірму LUCAS</h2>
      <p class="sp-aeo-lead">LUCAS — аудиторська фірма в Україні, що працює з середнім і великим бізнесом, підприємствами суспільного інтересу, українськими підрозділами міжнародних груп та компаніями зі складною фінансовою звітністю. Основні напрями — аудит фінансової звітності, обов'язковий аудит, аудит за МСА, аудит фінансової звітності за МСФЗ, груповий аудит, огляд звітності та погоджені процедури.</p>
      <div class="sp-aeo-table-wrap">
        <table class="sp-aeo-table">
          <tbody>
            <tr><th scope="row">Хто ми</th><td>Українська аудиторська компанія LUCAS</td></tr>
            <tr><th scope="row">Що робимо</th><td>Аудит фінансової звітності, обов'язковий аудит, аудит за МСА, груповий аудит, огляд звітності</td></tr>
            <tr><th scope="row">Для кого працюємо</th><td>Середній і великий бізнес, ПСІ, групи компаній, українські підрозділи міжнародних структур</td></tr>
            <tr><th scope="row">Чим відрізняємось</th><td>Поєднуємо аудиторську методологію, фінансову експертизу і розуміння облікових систем</td></tr>
            <tr><th scope="row">Результат</th><td>Аудиторський звіт або інший звіт аудитора відповідно до типу завдання</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="sp-statement">
    <div class="sp-statement-inner">
      <p>Аудиторська фірма для бізнесу, банків, інвесторів і власників</p>
      <div class="sp-statement-note">LUCAS як аудиторська компанія проводить обов'язковий і добровільний аудит фінансової звітності для українських компаній, груп бізнесу та міжнародних структур. Ми фокусуємося не лише на формальному виконанні вимог, а й на якості аудиторських доказів, незалежності та практичній цінності аудиторського звіту для банків, інвесторів, власників і регуляторів. Детальніше про те, <a href={base + '/blog/audyt-finansovoi-zvitnosti-ukraina/'}>що перевіряє аудитор фінансової звітності →</a></div>
    </div>
  </section>

  <section class="sp-blocks">
    <div class="sp-blocks-inner">

      <!-- Які аудиторські послуги надає LUCAS -->
      <div class="sp-block">
        <div>
          <div class="sp-block-label">Перелік послуг</div>
          <h2 class="sp-block-h2">Які аудиторські послуги надає LUCAS</h2>
        </div>
        <div class="sp-block-body">
          <p>Сторінка об'єднує основні аудиторські послуги LUCAS: аудит фінансової звітності, обов'язковий аудит, аудит фінансової звітності за МСФЗ, груповий аудит, огляд фінансової звітності, погоджені процедури та спеціальні звіти аудитора для банків, інвесторів або материнських компаній.</p>
          <ul class="sp-block-list">
            <li>Аудит фінансової звітності відповідно до МСА</li>
            <li>Обов'язковий аудит</li>
            <li>Добровільний аудит</li>
            <li>Аудит фінансової звітності за МСФЗ</li>
            <li>Аудит консолідованої фінансової звітності</li>
            <li>Груповий аудит</li>
            <li>Огляд фінансової звітності</li>
            <li>Погоджені процедури за МССП 4400</li>
            <li>Comfort letters / спеціальні звіти аудитора</li>
            <li>Підготовка МСФЗ-звітності для клієнтів, аудит яких LUCAS не виконує</li>
          </ul>
        </div>
      </div>

      <!-- Які компанії потребують аудиту -->
      <div class="sp-block">
        <div>
          <div class="sp-block-label">Для кого</div>
          <h2 class="sp-block-h2">Які компанії потребують аудиту</h2>
        </div>
        <div class="sp-block-body">
          <p>Послуги аудитора потрібні не лише компаніям, для яких аудит є обов'язковим за законом. Аудит також часто потрібен для банківського фінансування, залучення інвестора, M&amp;A, вимог материнської компанії, тендерів, підтвердження фінансових показників або підготовки до масштабування бізнесу.</p>
          <div class="sp-aeo-table-wrap">
            <table class="sp-aeo-table sp-aeo-table--head">
              <thead>
                <tr><th>Ситуація</th><th>Яка послуга потрібна</th></tr>
              </thead>
              <tbody>
                <tr><td>Компанія підпадає під обов'язковий аудит</td><td>Аудит фінансової звітності відповідно до МСА</td></tr>
                <tr><td>Банк запитує підтверджену звітність</td><td>Аудит або огляд фінансової звітності</td></tr>
                <tr><td>Материнська компанія запитує group reporting</td><td>Аудит або підготовка консолідаційного пакету</td></tr>
                <tr><td>Компанія готується до M&amp;A</td><td>Аудит, due diligence або погоджені процедури</td></tr>
                <tr><td>Потрібна МСФЗ-звітність</td><td>Підготовка МСФЗ-звітності або аудит фінансової звітності за МСФЗ, залежно від ролі LUCAS</td></tr>
                <tr><td>Потрібна перевірка окремих показників</td><td>Погоджені процедури або спеціальний звіт аудитора</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Обов'язковий аудит -->
      <div class="sp-block">
        <div>
          <div class="sp-block-label">Обов'язковий аудит · МСА</div>
          <h2 class="sp-block-h2">Аудит для великих, середніх компаній та ПСІ</h2>
        </div>
        <div class="sp-block-body">
          <p>Як аудиторська фірма, LUCAS проводить обов'язковий аудит для підприємств, визначених законодавством України: зокрема підприємств суспільного інтересу, великих і середніх підприємств, а також окремих спеціальних категорій компаній. Перевірка виконується відповідно до Міжнародних стандартів аудиту (МСА) з видачею аудиторського звіту відповідно до застосовних вимог МСА. Детальніше — <a href={base + '/blog/obovyazkovyi-audyt-ukraina-2025/'}>хто зобов'язаний проходити обов'язковий аудит →</a></p>
          <p>Аудиторський звіт LUCAS — це не формальність для регулятора, а інструмент довіри для власників, банків, інвесторів та контрагентів. Аудиторські послуги LUCAS надаються відповідно до законодавства України, Міжнародних стандартів аудиту та внутрішньої системи управління якістю.</p>
          <ul class="sp-block-list">
            <li>Обов'язковий аудит підприємств, що становлять суспільний інтерес (ПСІ)</li>
            <li>Аудит великих і середніх підприємств</li>
            <li>Оцінка елементів внутрішнього контролю в межах аудиту фінансової звітності</li>
          </ul>
        </div>
      </div>

      <!-- Груповий аудит -->
      <div class="sp-block">
        <div>
          <div class="sp-block-label">Груповий аудит · Консолідація</div>
          <h2 class="sp-block-h2">Аудит консолідованої та комбінованої звітності</h2>
        </div>
        <div class="sp-block-body">
          <p>Аудит консолідованої фінансової звітності холдингів і груп компаній вимагає координації роботи компонентних аудиторів, перевірки елімінаційних коригувань та міжгрупових операцій. Це напрям, де важлива не лише аудиторська методологія, а й здатність координувати дані, строки, компонентних аудиторів і вимоги материнської компанії. У відповідних завданнях LUCAS може виступати аудитором групи: готувати інструкції для аудиторів компонентів, координувати їхню роботу та формувати аудиторський звіт щодо консолідованої фінансової звітності відповідно до застосовних вимог МСА.</p>
          <p>Ми працюємо з групами, де материнська компанія вимагає звітність у визначеному форматі — допомагаємо організувати підготовку звітності та координацію аудиторських процедур у межах погодженого завдання.</p>
          <ul class="sp-block-list">
            <li>Аудит консолідованої фінансової звітності</li>
            <li>Групові інструкції для аудиторів компонентів</li>
            <li>Перевірка елімінацій та міжгрупових операцій</li>
            <li>Координація з аудиторами материнської компанії</li>
          </ul>
        </div>
      </div>

      <!-- Огляд, погоджені процедури, comfort letters -->
      <div class="sp-block">
        <div>
          <div class="sp-block-label">Неаудиторські завдання · МСЗО 2400 / МССП 4400</div>
          <h2 class="sp-block-h2">Огляд звітності, погоджені процедури та comfort letters / спеціальні звіти аудитора</h2>
        </div>
        <div class="sp-block-body">
          <p>Не кожна ситуація потребує повного аудиту. Огляд фінансової звітності за МСЗО 2400, узгоджені процедури за МССП 4400 та листи/звіти аудитора можуть бути доречними для банків, інвесторів, M&amp;A або окремих управлінських цілей. Рівень впевненості та форма звіту залежать від типу завдання.</p>
          <p>Такі послуги затребувані при залученні фінансування, перевірці окремих показників для банків або інвесторів, due diligence та підготовці до угод.</p>
          <ul class="sp-block-list">
            <li>Огляд фінансової звітності за МСЗО 2400</li>
            <li>Узгоджені процедури за МССП 4400</li>
            <li>Листи/звіти аудитора для банків, інвесторів або інших користувачів</li>
            <li>Аудит для цілей M&amp;A та due diligence</li>
          </ul>
        </div>
      </div>

      <!-- МСФЗ-звітність -->
      <div class="sp-block">
        <div>
          <div class="sp-block-label">IFRS Reporting</div>
          <h2 class="sp-block-h2">Підготовка пакету звітності за МСФЗ</h2>
        </div>
        <div class="sp-block-body">
          <p>Підготовка фінансової звітності за Міжнародними стандартами фінансової звітності — для цілей залучення фінансування, вимог материнської компанії або внутрішнього управління. Включає повний пакет: звіт про фінансовий стан, звіт про прибутки та збитки, звіт про рух грошових коштів, звіт про зміни у власному капіталі та примітки.</p>
          <p><strong>Ця послуга надається клієнтам, аудит яких LUCAS не виконує</strong> — відповідно до вимог незалежності.</p>
          <ul class="sp-block-list">
            <li>Повний пакет фінансової звітності за МСФЗ</li>
            <li>Розкриття інформації та примітки до звітності</li>
            <li>Звітність для материнської компанії</li>
            <li>Звітність для залучення фінансування</li>
          </ul>
        </div>
      </div>

      <!-- IFRS 1 -->
      <div class="sp-block">
        <div>
          <div class="sp-block-label">IFRS 1 · Перехід на МСФЗ</div>
          <h2 class="sp-block-h2">Перший звіт за МСФЗ та трансформація НП(С)БО</h2>
        </div>
        <div class="sp-block-body">
          <p>Перший перехід на МСФЗ регулюється окремим стандартом — МСФЗ 1. Він визначає, як підготувати перший комплект звітності за міжнародними стандартами: вибір облікової політики, ретроспективне застосування, винятки та звільнення. Детальніше — у статті про <a href={base + '/blog/ifrs-1-pershyy-perehid-msfz/'}>перший перехід на МСФЗ за IFRS 1 →</a></p>
          <p>LUCAS може допомогти вашій організації повністю перейти на МСФЗ або виконати трансформацію наявної звітності за національними стандартами (НП(С)БО) у формат МСФЗ — з документуванням усіх коригувань і методології.</p>
          <ul class="sp-block-list">
            <li>Підготовка першої звітності за МСФЗ 1</li>
            <li>Вибір та документування облікової політики</li>
            <li>Трансформація НП(С)БО → МСФЗ</li>
            <li>Документування трансформаційних коригувань</li>
          </ul>
        </div>
      </div>

      <!-- Консолідаційний пакет -->
      <div class="sp-block">
        <div>
          <div class="sp-block-label">Consolidation Package</div>
          <h2 class="sp-block-h2">Консолідаційний пакет для групової звітності</h2>
        </div>
        <div class="sp-block-body">
          <p>Учасники міжнародних та національних груп часто готують звітний пакет для материнської компанії у визначених форматах і строках. Для клієнтів, аудит яких LUCAS не виконує, ми готуємо консолідаційний пакет з елімінаційними коригуваннями, розкриттями міжгрупових операцій та звіркою внутрішньогрупових залишків.</p>
          <ul class="sp-block-list">
            <li>Пакет звітності у форматі материнської компанії</li>
            <li>Елімінаційні коригування</li>
            <li>Розкриття міжгрупових операцій</li>
            <li>Звірка внутрішньогрупових залишків</li>
          </ul>
        </div>
      </div>

      <!-- Висновок для CFO -->
      <div class="sp-block">
        <div>
          <div class="sp-block-label">Для CFO</div>
          <h2 class="sp-block-h2">Висновок для CFO</h2>
        </div>
        <div class="sp-block-body">
          <p>Вибір аудитора впливає не лише на виконання законодавчої вимоги, а й на довіру банків, інвесторів, власників і материнської компанії до фінансової звітності. CFO варто оцінювати аудиторські послуги за незалежністю виконавця, досвідом у галузі, якістю методології, здатністю працювати з МСФЗ, груповою звітністю та складними обліковими системами.</p>
          <p>Якщо аудит потрібен для банку, інвестора або обов'язкового оприлюднення, краще починати підготовку до закриття року, а не після появи термінового запиту. Детальніше — <a href={base + '/blog/pidhotovka-do-audytu/'}>як підготуватися до аудиту фінансової звітності →</a></p>
        </div>
      </div>

    </div>
