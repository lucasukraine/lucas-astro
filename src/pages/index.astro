---
// src/pages/index.astro
// Головна сторінка. Секції додаються поступово.
import BaseLayout from '../layouts/BaseLayout.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import Hero from '../components/Hero.astro';
import Concept from '../components/Concept.astro';
import Solutions from '../components/Solutions.astro';
import Industries from '../components/Industries.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import BlogStrip from '../components/BlogStrip.astro';
import Contact from '../components/Contact.astro';
import { homeFaq } from '../data/homeFaq';
import { getLatestPosts } from '../lib/blog';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const latestPosts = getLatestPosts(8).map(p => ({ category: p.category, title: p.cardTitle, href: p.href, date: p.date, readingTime: p.readingTime }));

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: homeFaq.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<BaseLayout
  title="LUCAS — Аудит, МСФЗ, SAF-T, ТЦУ та перехід з 1С та BAS на Odoo"
  description="Аудит фінансової звітності, SAF-T Connector, перехід на Odoo та трансфертне ціноутворення. LUCAS — аудиторська і технологічна компанія для великого та середнього бізнесу."
>
  <Fragment slot="head">
    <SchemaOrg schema={faqSchema} />
  </Fragment>
  <main id="top">
    <Hero />
    <Concept />
    <Solutions />
    <Industries />
    <Contact />
    <FaqAccordion
      eyebrow="Часті запитання"
      title="Питання, з якими до нас звертаються фінансові директори, головні бухгалтери та податкові команди"
      items={homeFaq}
    />
    <BlogStrip
      title="База знань"
      items={latestPosts}
      moreHref={base + '/blog/'}
    />
  </main>
</BaseLayout>
