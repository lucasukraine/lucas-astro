---
// src/pages/index.astro
// Головна сторінка. Секції додаються поступово.
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Principles from '../components/Principles.astro';
import Solutions from '../components/Solutions.astro';
import Industries from '../components/Industries.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import BlogStrip from '../components/BlogStrip.astro';
import Contact from '../components/Contact.astro';
import { homeFaq } from '../data/homeFaq';
import { blogPosts } from '../data/blogPosts';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="LUCAS — Аудиторська компанія нового типу"
  description="Поєднуємо аудит, фінансову експертизу та розробку для реалізації проєктів в сфері фінансів, обліку та податків."
>
  <main id="top">
    <Hero />
    <Principles />
    <Solutions />
    <Industries />
    <Contact />
    <FaqAccordion
      eyebrow="Часті запитання"
      title="Що варто знати"
      items={homeFaq}
    />
    <BlogStrip
      items={blogPosts}
      moreHref={base + '/blog/'}
    />
  </main>
</BaseLayout>
