---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import ServiceAeo from '../../components/ServiceAeo.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import ServiceCTA from '../../components/ServiceCTA.astro';
import ServiceBlogBlock from '../../components/ServiceBlogBlock.astro';
import { transferPricingFaq } from '../../data/transferPricingFaq';
const base = import.meta.env.BASE_URL;
---

<ServiceLayout
  title="Трансфертне ціноутворення — ТЦ документація та звіт про КО | LUCAS"
  description="Трансфертне ціноутворення: документація, benchmark-аналіз і захист позиції щодо контрольованих операцій за ст. 39 ПКУ з урахуванням підходів ОЕСР. Реєстр КО, майстер-файл, звіт про КО."
>
  <ServiceHero
    eyebrow="Послуга 04"
    title="Трансфертне ціноутворення"
    lead="Документація, аналіз і захист позиції щодо контрольованих операцій відповідно до ст. 39 Податкового кодексу України з урахуванням підходів ОЕСР до трансфертного ціноутворення — для компаній з внутрішньогруповими операціями, операціями з пов'язаними особами та іншими операціями, які можуть визнаватися контрольованими відповідно до вимог ПКУ."
  />

  <ServiceAeo
    title="Коротко про трансфертне ціноутворення"
    lead={`Трансфертне ціноутворення — це правила для операцій між пов'язаними особами, нерезидентами з низькоподаткових юрисдикцій та іншими контрагентами, визначеними Податковим кодексом України. Для компанії головне питання — не лише "чи є у нас контрольовані операції?", а чи правильно визначено пов'язаних осіб, пороги, метод ТЦУ, ринковий діапазон і доказову базу для позиції перед ДПС.`}
    rows={[
      { label: 'Що це',                    value: 'Трансфертне ціноутворення — це система правил, яка перевіряє, чи відповідають умови контрольованих операцій принципу "витягнутої руки".' },
      { label: 'Кого стосується',          value: 'Компаній, які мають операції з пов\'язаними нерезидентами, контрагентами з низькоподаткових юрисдикцій, нерезидентами зі спеціальними організаційно-правовими формами або іншими сторонами, визначеними ПКУ.' },
      { label: 'Що перевіряється',         value: 'Ціни, маржа, функції сторін, ризики, активи, умови договорів, економічна суть операцій, зіставні компанії або операції та відповідність обраного методу ТЦУ.' },
      { label: 'Які методи застосовуються', value: 'ПКУ передбачає п\'ять основних методів ТЦУ: метод порівняльної неконтрольованої ціни, ціни перепродажу, "витрати плюс", чистого прибутку та розподілення прибутку. Метод обирається залежно від типу операції, доступності зіставних даних, функцій сторін, ризиків і економічної суті операції.' },
      { label: 'Що потрібно підготувати',  value: 'Звіт про контрольовані операції, повідомлення про участь у міжнародній групі компаній, документацію з трансфертного ціноутворення, функціональний аналіз і benchmark-дослідження — залежно від статусу платника та вимог ПКУ.' },
      { label: 'Основний ризик',           value: 'Найчастіші помилки — пропустити пов\'язану особу, неправильно визначити контрольовану операцію, не врахувати вартісні пороги, обрати слабкий метод ТЦУ або підготувати документацію без достатньої доказової бази.' },
      { label: 'Результат',                value: 'Коректно визначені контрольовані операції, обраний і обґрунтований метод ТЦУ, підготовлена звітність і документація, розрахований ринковий діапазон та позиція, яку можна захищати під час запиту або перевірки ДПС.' },
    ]}
  />

  <section class="sp-statement">
    <div class="sp-statement-inner">
      <p>Якість документації залежить від глибини функціонального аналізу та доказовості обраної методології.</p>
      <div class="sp-statement-note">Трансфертне ціноутворення в Україні регулюється ст. 39 ПКУ та будується на принципі «витягнутої руки» відповідно до настанов ОЕСР/BEPS. Недотримання вимог може призвести до донарахувань та штрафних санкцій за результатами перевірки ДПС.</div>
    </div>
  </section>

  <section class="sp-blocks">
    <div class="sp-blocks-inner">

      <div class="sp-block">
        <div>
          <div class="sp-block-label">Ідентифікація · Ст. 39 ПКУ</div>
          <h2 class="sp-block-h2">Реєстр контрольованих операцій</h2>
        </div>
        <div class="sp-block-body">
          <p>Першим кроком є визначення кола повʼязаних осіб, ідентифікація контрольованих операцій і перевірка відповідності критеріям визнання операцій контрольованими згідно з актуальними вимогами Податкового кодексу України.</p>
          <p>LUCAS готує реєстр контрольованих операцій — основу для подальшої документації та звітності.</p>
          <ul class="sp-block-list">
            <li>Визначення кола повʼязаних осіб</li>
            <li>Ідентифікація контрольованих операцій</li>
            <li>Перевірка критеріїв визнання операцій КО</li>
            <li>Підготовка реєстру контрольованих операцій</li>
          </ul>
        </div>
      </div>

      <div class="sp-block">
        <div>
          <div class="sp-block-label">ОЕСР · МГК · Тристороння структура</div>
          <h2 class="sp-block-h2">Майстер-файл і локальний файл</h2>
        </div>
        <div class="sp-block-body">
          <p>Для учасників міжнародних груп компаній (МГК), що відповідають критеріям ПКУ, документація готується відповідно до тристоронньої структури ОЕСР. Вона включає повідомлення про участь у МГК, майстер-файл (опис глобального бізнесу групи) і локальний файл.</p>
          <p>Локальний файл містить функціональний аналіз, аналіз ризиків і ТЦУ-аналіз контрольованих операцій з обґрунтуванням обраного методу ціноутворення.</p>
          <ul class="sp-block-list">
            <li>Повідомлення про участь у міжнародній групі компаній</li>
            <li>Майстер-файл — опис глобального бізнесу групи</li>
            <li>Локальний файл — функціональний аналіз і ТЦУ-аналіз</li>
            <li>Обґрунтування методу трансфертного ціноутворення</li>
          </ul>
        </div>
      </div>

      <div class="sp-block">
        <div>
          <div class="sp-block-label">Звітність · ДПС</div>
          <h2 class="sp-block-h2">Звіт про контрольовані операції</h2>
        </div>
        <div class="sp-block-body">
          <p>Підготовка та подання річного звіту про контрольовані операції до Державної податкової служби відповідно до форм і строків, встановлених ст. 39.4 ПКУ. LUCAS допомагає перевірити повноту і коректність відображення контрольованих операцій на основі наданої клієнтом інформації та результатів аналізу.</p>
          <ul class="sp-block-list">
            <li>Підготовка річного звіту про КО</li>
            <li>Подання звіту до ДПС у встановлені строки</li>
            <li>Контроль повноти відображення операцій</li>
          </ul>
        </div>
      </div>

      <div class="sp-block">
        <div>
          <div class="sp-block-label">Benchmark · Принцип витягнутої руки</div>
          <h2 class="sp-block-h2">Порівняльний аналіз і ринковий діапазон</h2>
        </div>
        <div class="sp-block-body">
          <p>Benchmark-аналіз — один із ключових елементів TP-документації. LUCAS виконує пошук зіставних компаній у комерційних базах даних, статистичний аналіз ринкового діапазону (P25–P75) і документальне обґрунтування відповідності умов контрольованих операцій принципу «витягнутої руки» відповідно до ПКУ та настанов ОЕСР.</p>
          <p>Якісний benchmark-аналіз суттєво посилює доказову силу документації під час перевірки.</p>
          <ul class="sp-block-list">
            <li>Пошук зіставних компаній у комерційних базах даних</li>
            <li>Статистичний аналіз ринкового діапазону (P25–P75)</li>
            <li>Обґрунтування принципу «витягнутої руки»</li>
            <li>Документування методології аналізу</li>
          </ul>
        </div>
      </div>

      <div class="sp-block">
        <div>
          <div class="sp-block-label">TP Policies · APA</div>
          <h2 class="sp-block-h2">Внутрішньогрупові політики та попереднє ціноутворення</h2>
        </div>
        <div class="sp-block-body">
          <p>Превентивна ТЦУ-політика зазвичай дешевша та ефективніша, ніж реакція на запит або перевірку ДПС. LUCAS розробляє TP-policies для групи: методологію ціноутворення, договірну базу, розподіл функцій і ризиків між учасниками групи.</p>
          <p>Для великих платників податків, які прагнуть більшої визначеності щодо регулярних контрольованих операцій, ми супроводжуємо процедуру попереднього узгодження ціноутворення з ДПС.</p>
          <ul class="sp-block-list">
            <li>Розробка TP-policies для групи компаній</li>
            <li>Методологія ціноутворення та договірна база</li>
            <li>Розподіл функцій і ризиків між учасниками</li>
            <li>Супровід переговорів щодо APA</li>
          </ul>
        </div>
      </div>

      <div class="sp-block">
        <div>
          <div class="sp-block-label">Tax Defense · Перевірки ДПС</div>
          <h2 class="sp-block-h2">Захист позиції під час податкових перевірок</h2>
        </div>
        <div class="sp-block-body">
          <p>LUCAS супроводжує клієнта на ключових етапах взаємодії з ДПС щодо трансфертного ціноутворення: оцінка ТЦУ-ризиків до початку перевірки, підготовка аргументованих відповідей на запити, супровід під час перевірки.</p>
          <p>У разі донарахувань — підготовка економічної та методологічної позиції для заперечень на акт перевірки.</p>
          <ul class="sp-block-list">
            <li>Оцінка TP-ризиків до початку перевірки</li>
            <li>Аргументовані відповіді на запити ДПС</li>
            <li>Супровід під час податкової перевірки</li>
            <li>Підготовка заперечень до акта перевірки у разі донарахувань</li>
          </ul>
        </div>
      </div>

    </div>
  </section>

  <FaqAccordion
    eyebrow="Часті запитання"
    title="Що варто знати"
    items={transferPricingFaq}
  />

  <ServiceCTA
    title="Потрібна ТЦ-документація, звіт або захист позиції"
    titlePunct="?"
    text="Розкажіть про ваші контрольовані операції — ми оцінимо обсяг документації та запропонуємо умови."
    href={base + '/#contact'}
    linkText="Залишити запит"
  />

  <ServiceBlogBlock
    service="transfer-pricing"
    title="Блог про трансфертне ціноутворення"
    subtitle="Пояснюємо контрольовані операції, звіт про КО, ТЦУ-документацію, пов'язаних осіб, МГК та ризики податкових перевірок."
    moreHref={base + '/blog/'}
  />

</ServiceLayout>
