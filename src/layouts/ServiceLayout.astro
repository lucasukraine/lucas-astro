---
// ServiceLayout.astro
// Layout для сторінок послуг. Обгортає BaseLayout, додає <main>.
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  lang?: 'uk' | 'en';
}

const { title, description, lang = 'uk' } = Astro.props;
---

<BaseLayout title={title} description={description} lang={lang}>
  <main>
    <slot />
  </main>
</BaseLayout>
