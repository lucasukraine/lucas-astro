---
// Footer.astro
// Еталон: other-services/index.html
// URL-и конвертовані з /lucas-website/* → /*
// SVG логотип рендериться через #lucas-mark, визначений у Header.astro
const { lang = 'uk' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const p = lang === 'en' ? '/en' : '';

const t = {
  tagline:     lang === 'en' ? 'Audit, technology and expertise — one team.' : 'Аудит, технологія і досвід — в одній команді',
  legalName:   lang === 'en' ? 'Lucas Audit LLC'                             : 'ТОВ «Лукас Аудит»',
  legalDesc:   lang === 'en' ? 'Audit & Technology Company'                  : 'Аудиторська та технологічна компанія',
  services:    lang === 'en' ? 'Services'                                    : 'Послуги',
  audit:       lang === 'en' ? 'Audit & Reporting'                           : 'Аудит та звітність',
  saft:        lang === 'en' ? 'SAF-T Connector'                             : 'SAF-T Connector',
  odoo:        lang === 'en' ? 'Migration to Odoo'                           : 'Міграція на Odoo',
  tp:          lang === 'en' ? 'Transfer Pricing'                            : 'Трансфертне ціноутворення',
  other:       lang === 'en' ? 'Other Services'                              : 'Інші послуги',
  company:     lang === 'en' ? 'Company'                                     : 'Компанія',
  concept:     lang === 'en' ? 'Concept'                                     : 'Концепція',
  industries:  lang === 'en' ? 'Industries'                                  : 'Галузі',
  faq:         lang === 'en' ? 'FAQ'                                         : 'Часті питання',
  blog:        'Блог',
  documents:   lang === 'en' ? 'Documents'                                   : 'Документи',
  contacts:    lang === 'en' ? 'Contacts'                                    : 'Контакти',
  connect:     lang === 'en' ? 'Connect'                                     : "Зв'язатись",
  phone:       lang === 'en' ? 'Phone'                                       : 'Телефон',
  address:     lang === 'en' ? 'Address'                                     : 'Адреса',
  showEmail:   lang === 'en' ? 'Show email'                                  : 'Показати email',
  cta:         lang === 'en' ? 'Discuss a project →'                         : 'Обговорити проєкт →',
};
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-grid">

      <!-- Brand -->
      <div class="footer-brand">
        <a aria-label="LUCAS" class="footer-mark" href="#top">
          <svg aria-hidden="true" class="logo-svg"><use href="#lucas-mark"></use></svg>
        </a>
        <p class="footer-tagline">
          {t.tagline}{lang === 'uk' && <span class="op">.</span>}
        </p>
        <p class="footer-legal">
          {t.legalName}<br />
          {t.legalDesc}
        </p>
      </div>

      <!-- Services -->
      <div>
        <div class="footer-col-label">{t.services}</div>
        <ul>
          <li><a href={base + p + '/audit/'}>{t.audit}</a></li>
          <li><a href={base + p + '/saf-t/'}>{t.saft}</a></li>
          <li><a href={base + p + '/odoo-migration/'}>{t.odoo}</a></li>
          <li><a href={base + p + '/transfer-pricing/'}>{t.tp}</a></li>
          <li><a href={base + p + '/other-services/'}>{t.other}</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <div class="footer-col-label">{t.company}</div>
        <ul>
          <li><a href={base + p + '/#concept'}>{t.concept}</a></li>
          <li><a href={base + p + '/#industries'}>{t.industries}</a></li>
          <li><a href={base + p + '/#faq'}>{t.faq}</a></li>
          {lang === 'uk' && <li><a href={base + '/blog/'}>{t.blog}</a></li>}
          <li><a href={base + p + '/documents/'}>{t.documents}</a></li>
          <li><a href={base + p + '/#contact'}>{t.contacts}</a></li>
        </ul>
      </div>

      <!-- Contacts -->
      <div class="footer-contact">
        <div class="footer-col-label">{t.connect}</div>
        <div class="footer-contact-row">
          <span class="footer-contact-lbl">Email</span>
          <button class="footer-contact-val email-reveal" id="footer-email-reveal" type="button">
            {t.showEmail}
          </button>
        </div>
        <div class="footer-contact-row">
          <span class="footer-contact-lbl">{t.phone}</span>
          <a class="footer-contact-val" href="tel:+380443447915">+380 44 344 7915</a>
        </div>
        <div class="footer-contact-row">
          <span class="footer-contact-lbl">{t.address}</span>
          <span class="footer-contact-val">
            {lang === 'en' ? (
              <>Kyiv, 1a Sportyvna Sq.<br />Gulliver BC, Tower A, 17th fl.</>
            ) : (
              <>м. Київ, пл. Спортивна 1а<br />БЦ Гулівер, Вежа А, 17 пов.</>
            )}
          </span>
        </div>
      </div>

    </div>

    <div class="footer-bot">
      <span class="footer-bot-copy">
        © <span id="footer-year"></span> LUCAS · {t.legalName} · All rights reserved
      </span>
      <a class="footer-bot-cta" href={base + p + '/#contact'}>{t.cta}</a>
    </div>
  </div>
</footer>

<script is:inline>
  (() => {
    // Поточний рік у copyright рядку
    const yr = document.getElementById('footer-year');
    if (yr) yr.textContent = new Date().getFullYear();

    // Email reveal — обфускація від спам-парсерів
    const btn = document.getElementById('footer-email-reveal');
    if (!btn) return;
    btn.addEventListener('click', () => {
      const u = 'info', d = 'lucasua' + '.com';
      const a = document.createElement('a');
      a.href = 'mailto:' + u + '\u0040' + d;
      a.textContent = u + '\u0040' + d;
      a.className = 'footer-contact-val';
      a.style.color = 'rgba(255,255,255,.6)';
      btn.replaceWith(a);
    }, { once: true });
  })();
</script>
