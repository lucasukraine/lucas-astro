---
// ArticleTocCta.astro
// Компактна CTA-картка одразу під змістом статті (.art-toc) — щоб питання
// вартості не вимагало скролу до кінця статті (де стоїть ArticleCTA).
//
// ПРАВИЛО для prop `text` (кастомізація дозволена й заохочується, але):
// питання має стосуватись ОСНОВНОЇ послуги LUCAS, під яку написана стаття
// (аудит / перехід з 1С-BAS на Odoo / SAF-T Connector / ТЦУ), або вартості
// цієї послуги — і нічого іншого (не побічної дії на кшталт "оцінити
// статус компанії" чи "діагностика готовності", яка не є послугою LUCAS
// з чіткою вартістю). Кнопка завжди "Запитати вартість" — текст має
// логічно поєднуватись із цим закликом. Якщо немає точної релевантної
// формули — не кастомізуй, лишай дефолтне значення нижче.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

interface Props {
  text?: string;
  href?: string;
  linkText?: string;
}

const {
  text = 'Потрібні послуги щодо цієї теми?',
  href = base + '/#contact',
  linkText = 'Запитати вартість',
} = Astro.props;
---

<aside class="art-toc-cta">
  <p class="art-toc-cta-text">{text}</p>
  <a class="btn cta-orange" href={href}>{linkText} <span class="arrow"></span></a>
</aside>
