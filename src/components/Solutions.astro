      <a class="arrow-link on-dark" href={base + '/other-services/'}>Дізнатися більше</a>
    </div>
    <div class="service-features">

      <div class="fc-divider">
        <span class="fc-divider-label">Послуги з фінансів та права</span>
        <span class="fc-divider-line"></span>
