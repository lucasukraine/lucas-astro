</section>

<script>
  // Service chapters — context (left) fades in, fc cards stagger in
  (() => {
    const cardDelays = [0, 80, 170, 255, 345];
    document.querySelectorAll('.service-chapter').forEach(chapter => {
      const context = chapter.querySelector('.service-context');
      const cards   = Array.from(chapter.querySelectorAll('.fc'));
      const io = new IntersectionObserver(entries => {
        if (!entries[0].isIntersecting) return;
        if (context) context.classList.add('is-visible');
        cards.forEach((card, i) => {
          setTimeout(() => card.classList.add('is-visible'), cardDelays[i] ?? i * 85);
        });
        io.disconnect();
      }, { threshold: 0.05 });
      io.observe(chapter);
    });
  })();

  // Mobile accordion — inject trigger button for each chapter at < 720px
  (() => {
    if (window.innerWidth > 720) return;
    document.querySelectorAll('.service-chapter').forEach(chapter => {
      const ctx  = chapter.querySelector('.service-context');
      const num  = chapter.querySelector('.service-num');
      const name = chapter.querySelector('.service-name');
      if (!ctx || !name) return;
      const trigger = document.createElement('button');
      trigger.className = 'svc-mob-trigger';
      trigger.setAttribute('aria-expanded', 'false');
      trigger.innerHTML = `
        <div class="svc-mob-trigger-inner">
          <span class="svc-mob-num">${num ? num.textContent : ''}</span>
          <span class="svc-mob-name">${name.textContent}</span>
        </div>
        <span class="svc-mob-icon" aria-hidden="true"></span>`;
      ctx.insertBefore(trigger, ctx.firstChild);
      trigger.addEventListener('click', () => {
        const isOpen = chapter.classList.contains('mob-open');
        chapter.classList.toggle('mob-open', !isOpen);
        trigger.setAttribute('aria-expanded', String(!isOpen));
      });
    });
  })();
</script>
