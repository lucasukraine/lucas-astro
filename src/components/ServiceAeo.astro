---
interface Props {
  title: string;
  lead: string;
  rows: { label: string; value: string }[];
}
const { title, lead, rows } = Astro.props;
---

<section class="sp-aeo">
  <div class="sp-aeo-inner">
    <h2 class="sp-aeo-h2">{title}</h2>
    <p class="sp-aeo-lead">{lead}</p>
    <div class="sp-aeo-table-wrap">
      <table class="sp-aeo-table">
        <tbody>
          {rows.map(row => (
            <tr>
              <th scope="row">{row.label}</th>
              <td>{row.value}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
