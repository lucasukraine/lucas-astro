---
interface Props {
  eyebrow: string;
  title: string;
  lead: string;
  breadcrumb?: string;
  accent?: 'orange' | 'cyan';
  productUrl?: string;
  productLabel?: string;
}
const { eyebrow, title, lead, breadcrumb, accent = 'orange', productUrl, productLabel } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="sp-hero">
  <div class="sp-hero-deco" aria-hidden="true"></div>
  <div class="sp-hero-inner">
    <nav class="sp-breadcrumb" aria-label="Хлібні крихти">
      <a href={base + '/'}>Головна</a>
      <span>/</span>
      <a href={base + '/#services'}>Послуги</a>
      <span>/</span>
      <span class="sp-breadcrumb-current">{breadcrumb ?? title}</span>
    </nav>
    <div class:list={['sp-eyebrow', { cyan: accent === 'cyan' }]}>{eyebrow}</div>
    <h1 class="sp-h1">{title}</h1>
    <p class="sp-lead">{lead}</p>
    <div class="sp-hero-actions">
      <a class="btn cta-orange" href={base + '/#contact'}>Запитати вартість <span class="arrow"></span></a>
      <a class="btn ghost-dark" href={base + '/#services'}>Усі послуги</a>
    </div>
    {productUrl && (
      <a class="sp-product-link" href={productUrl} target="_blank" rel="noopener noreferrer">
        {productLabel ?? productUrl.replace(/^https?:\/\//, '')} <span class="sp-product-link-icon" aria-hidden="true">↗</span>
      </a>
    )}
  </div>
</section>
