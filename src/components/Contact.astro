---
const { lang = 'uk' } = Astro.props;

const t = {
  eyebrow:    lang === 'en' ? 'Contacts'          : 'Контакти',
  taglineA:   lang === 'en' ? 'Tell us about your project' : 'Початок розмови',
  taglineB:   lang === 'en' ? 'Discuss an accounting, tax or technology challenge.' : 'Сильні проєкти починаються з якісного діалогу.',
  stmtQ:      lang === 'en'
    ? 'If you face challenges in accounting, tax or digital finance transformation — write to us.'
    : 'Якщо перед вами стоять завдання в сфері обліку, податків чи цифрової трансформації фінансів — напишіть нам.',
  stmtQEmEn:  lang === 'en' ? 'accounting, tax or digital finance transformation' : '',
  stmtQEmUk:  lang === 'en' ? '' : 'цифрової трансформації фінансів',
  stmtP:      lang === 'en'
    ? 'The LUCAS team will read your request and get back to you within one business day. No unnecessary forms — just a focused first conversation.'
    : 'Розкажіть, яку задачу потрібно вирішити. Ми швидко зорієнтуємося в контексті, визначимо релевантну команду та запропонуємо наступний крок.',
  phone:      lang === 'en' ? 'Phone'   : 'Телефон',
  phoneDays:  lang === 'en' ? 'Mon–Fri' : 'Пн–Пт',
  email:      'Email',
  office:     lang === 'en' ? 'Office'  : 'Офіс',
  officeVal:  lang === 'en'
    ? 'Sportyvna Square 1a, BC Gulliver, Tower A, 17th floor · Kyiv, 01601'
    : 'пл. Спортивна 1а, БЦ Гулівер, Вежа А, 17 поверх · м. Київ, 01601',
  showEmail:  lang === 'en' ? 'Show email'  : 'Показати email',
  formTitle:  lang === 'en' ? 'Send a request' : 'Надіслати запит',
  formSub:    lang === 'en' ? 'Briefly describe your task — we will get back to you the next business day.' : 'Ми ознайомимось з контекстом і зв\'яжемось з вами для короткого обговорення задачі.',
  fieldName:  lang === 'en' ? 'Name'          : "Ім'я",
  fieldEmail: 'Email',
  fieldPhone: lang === 'en' ? 'Phone'         : 'Телефон',
  fieldMsg:   lang === 'en' ? 'Briefly describe your project' : 'Коротко про задачу',
  submit:     lang === 'en' ? 'Send request'  : 'Надіслати запит',
  foot:       lang === 'en' ? 'No bureaucracy · straight to the point' : 'Без довгих очікувань · одразу до справи',
};
---

<section class="contact" id="contact">
  <div class="container">

    <div class="contact-intro reveal">
      <div class="eyebrow cyan-dot">{t.eyebrow}</div>
    </div>

    <h2 class="contact-tagline reveal" data-d="1">
      <span class="contact-tagline-a">{t.taglineA}<span class="op">.</span></span>
      <span class="contact-tagline-b">{t.taglineB}</span>
    </h2>

    <div class="contact-spread">

      <!-- INTRO TEXT: desktop — left col top; mobile — first (before form) -->
      <div class="contact-intro-text reveal" data-d="2">
        <p class="contact-statement-q">
          {lang === 'en'
            ? <Fragment>If you face challenges in <em>accounting, tax or digital finance transformation</em> — write to us.</Fragment>
            : <Fragment>Якщо перед вами стоять завдання в сфері обліку, податків чи <em>цифрової трансформації фінансів</em> — напишіть нам.</Fragment>
          }
        </p>
        <p class="contact-statement-p">{t.stmtP}</p>
      </div>

      <!-- FORM: desktop — right col (spans both rows); mobile — second -->
      <aside class="contact-residency has-corner reveal" data-d="3">
        <div class="residency-head">
          <span class="residency-title">{t.formTitle}</span>
          <span class="residency-meta">RES · #001</span>
        </div>
        <p class="residency-sub">{t.formSub}</p>

        <form class="residency-form" id="lucas-contact-form" novalidate>
          <div class="field">
            <input type="text" id="cf-name" name="name" placeholder=" " required autocomplete="name">
            <label for="cf-name" class="field-label">{t.fieldName}</label>
          </div>
          <div class="field">
            <input type="email" id="cf-email" name="email" placeholder=" " required autocomplete="email">
            <label for="cf-email" class="field-label">{t.fieldEmail}</label>
          </div>
          <div class="field">
            <input type="tel" id="cf-phone" name="phone" placeholder=" " required autocomplete="tel">
            <label for="cf-phone" class="field-label">{t.fieldPhone}</label>
          </div>
          <div class="field">
            <textarea id="cf-message" name="message" placeholder=" " required rows="4"></textarea>
            <label for="cf-message" class="field-label">{t.fieldMsg}</label>
          </div>
          <!-- Honeypot — прихована пастка для ботів, люди не бачать і не заповнюють -->
          <div class="hp-field">
            <input type="text" name="website" tabindex="-1" autocomplete="off">
          </div>
          <!-- Прихована мітка сайту — щоб розрізняти запити з різних сайтів, які використовують цю саму форму/EmailJS-акаунт -->
          <input type="hidden" name="site_name" value="LUCAS">
          <button type="submit" class="residency-submit" id="lucas-submit">
            {t.submit} <span class="arrow"></span>
          </button>
          <div class="residency-foot">{t.foot}</div>
        </form>
      </aside>

      <!-- DETAILS: desktop — left col bottom; mobile — third (after form) -->
      <div class="contact-statement reveal" data-d="2">
        <div class="contact-ledger">
          <div class="ledger-row">
            <span class="lr-label">{t.phone}</span>
            <a class="lr-value" href="tel:+380443447915">+380 44 344 7915</a>
            <span class="lr-hint">{t.phoneDays}</span>
          </div>
          <div class="ledger-row">
            <span class="lr-label">{t.email}</span>
            <button class="lr-value email-reveal" id="contact-email-reveal" type="button">{t.showEmail}</button>
            <span class="lr-hint">24 / 7</span>
          </div>
          <div class="ledger-row">
            <span class="lr-label">{t.office}</span>
            <span class="lr-value small">
              {lang === 'en'
                ? <Fragment>Sportyvna Square 1a, BC Gulliver<br />Tower A, 17th floor · Kyiv, 01601</Fragment>
                : <Fragment>пл. Спортивна 1а, БЦ Гулівер<br />Вежа А, 17 поверх · м. Київ, 01601</Fragment>
              }
            </span>
            <span class="lr-hint">UA</span>
          </div>
        </div>

        <div class="contact-hours">
          <div class="contact-hours-cell">
            <span class="ch-val">&lt; 24<span class="ch-unit">год</span></span>
            <span class="ch-label">Time to reply</span>
          </div>
          <div class="contact-hours-cell">
            <span class="ch-val">UTC<span class="ch-unit">+2</span></span>
            <span class="ch-label">Working zone</span>
          </div>
          <div class="contact-hours-cell">
            <span class="ch-val">UA · EN</span>
            <span class="ch-label">Languages</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script is:inline>
(function () {
  var form = document.getElementById('lucas-contact-form');
  if (!form) return;

  // ─── Динамічне завантаження EmailJS ──────────────────────────
  // Defer until contact section enters viewport to avoid blocking first paint
  var ejsLoaded = false;
  var formLoadTime = 0;
  function loadEmailJS() {
    if (ejsLoaded) return;
    var s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js';
    s.onload = function () {
      if (window.emailjs) { window.emailjs.init({ publicKey: 'iY16Y2CF5ffzdZCbh' }); ejsLoaded = true; }
    };
    s.onerror = function () { console.warn('[Contact] EmailJS не вдалось завантажити.'); };
    document.head.appendChild(s);
  }
  var contactSection = form.closest('section') || form;
  if ('IntersectionObserver' in window) {
    var _io = new IntersectionObserver(function(entries) {
      if (entries[0].isIntersecting) { formLoadTime = Date.now(); loadEmailJS(); _io.disconnect(); }
    }, { rootMargin: '300px' });
    _io.observe(contactSection);
  } else {
    formLoadTime = Date.now();
    loadEmailJS();
  }

  // ─── Email reveal (lightweight, runs immediately) ────────────
  var revealBtn = document.getElementById('contact-email-reveal');
  if (revealBtn) {
    revealBtn.addEventListener('click', function () {
      var addr = 'info' + '@' + 'lucasua.com';
      var a = document.createElement('a');
      a.href = 'mailto:' + addr;
      a.textContent = addr;
      a.className = 'lr-value';
      revealBtn.replaceWith(a);
    }, { once: true });
  }

  // ─── Validation + Submit — deferred to idle ───────────────────
  // Contact form is below the fold; users must scroll before interacting.
  // Deferring setup avoids DOM queries + addEventListener blocking first load.
  function initForm() {
  var validators = {
    name:    function (v) { return v.trim().length >= 2; },
    email:   function (v) { return /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(v.trim()); },
    phone:   function (v) { return /^[\+]?[\d\s\-\(\)]{7,20}$/.test(v.trim()); },
    message: function (v) { return v.trim().length >= 5; },
  };
  var isEn = document.documentElement.lang === 'en';
  var errorMessages = isEn ? {
    name:    'Enter your name',
    email:   'Enter a valid email (e.g. name@company.com)',
    phone:   'Enter a valid phone number',
    message: 'Please describe your task briefly',
  } : {
    name:    "Введіть ім'я",
    email:   'Введіть коректний email (наприклад: name@company.com)',
    phone:   'Введіть коректний номер телефону',
    message: 'Опишіть задачу коротко',
  };

  function validateField(input) {
    var name = input.name;
    var ok   = validators[name] ? validators[name](input.value) : input.value.trim().length > 0;
    var wrap = input.closest('.field');
    var err  = wrap && wrap.querySelector('.field-err-msg');

    if (!ok) {
      input.classList.add('field-error');
      if (wrap && !err) {
        err = document.createElement('span');
        err.className = 'field-err-msg';
        wrap.appendChild(err);
      }
      if (err) err.textContent = errorMessages[name] || 'Невірний формат';
    } else {
      input.classList.remove('field-error');
      if (err) err.remove();
    }
    return ok;
  }

  form.querySelectorAll('input[name], textarea[name]').forEach(function (f) {
    f.addEventListener('blur', function () { if (f.value) validateField(f); });
    f.addEventListener('input', function () {
      if (f.classList.contains('field-error')) validateField(f);
    });
  });

  // ─── Submit ───────────────────────────────────────────────────
  var btn = document.getElementById('lucas-submit');
  var submitted = false;

  // ─── Spam filters ─────────────────────────────────────────────
  var BLOCKED_DOMAINS = ['jmailservice.com','mailservice.com','yopmail.com',
    'guerrillamail.com','tempmail.com','throwaway.email','maildrop.cc',
    'sharklasers.com','spam4.me','trashmail.com','dispostable.com'];
  var SPAM_PHRASES = ['appear first','rank higher','rank #1',
    'first page of google','increase your traffic','increase traffic',
    'search engine optimization service','guaranteed clicks','buy backlinks',
    'link building service','would you take that spot'];
  function isBlockedDomain(email) {
    var parts = email.split('@');
    return parts.length === 2 && BLOCKED_DOMAINS.indexOf(parts[1].toLowerCase()) !== -1;
  }
  function containsUrl(text) { return /https?:\/\/|www\./i.test(text); }
  function hasSpamPhrases(text) {
    var lower = text.toLowerCase();
    for (var i = 0; i < SPAM_PHRASES.length; i++) {
      if (lower.indexOf(SPAM_PHRASES[i]) !== -1) return true;
    }
    return false;
  }

  form.addEventListener('submit', function (e) {
    e.preventDefault();

    // Honeypot
    if (form.querySelector('[name="website"]').value) return;
    if (submitted) return;

    // Time-based check: block submissions under 5s (bot behaviour)
    if (formLoadTime && (Date.now() - formLoadTime) < 5000) return;

    var msgInput   = form.querySelector('[name="message"]');
    var emailInput = form.querySelector('[name="email"]');
    var msgVal     = msgInput   ? msgInput.value          : '';
    var emailVal   = emailInput ? emailInput.value.trim() : '';

    // Silent spam checks (no feedback to spammer)
    if (hasSpamPhrases(msgVal) || isBlockedDomain(emailVal)) return;

    // URL in message — show error so real users can fix it
    if (containsUrl(msgVal)) {
      var msgWrap = msgInput.closest('.field');
      var urlErr  = msgWrap && msgWrap.querySelector('.field-err-msg');
      msgInput.classList.add('field-error');
      if (msgWrap && !urlErr) {
        urlErr = document.createElement('span');
        urlErr.className = 'field-err-msg';
        msgWrap.appendChild(urlErr);
      }
      if (urlErr) urlErr.textContent = isEn
        ? 'Please describe your task without URLs'
        : 'Опишіть задачу без посилань';
      msgInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }

    // Validate all fields
    var fields = Array.from(form.querySelectorAll('input[name], textarea[name]'))
                      .filter(function (f) { return f.name !== 'website'; });
    var allOk  = fields.map(validateField).every(Boolean);
    if (!allOk) {
      var first = form.querySelector('.field-error');
      if (first) first.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }

    // EmailJS guard
    if (!window.emailjs || !ejsLoaded) {
      var noEjs = document.createElement('p');
      noEjs.style.cssText = 'color:rgba(255,92,31,.9);font-size:13px;margin-top:10px;font-family:var(--mono)';
      noEjs.textContent = isEn
        ? 'The sending service is still loading. Please try again or write to info@lucasua.com'
        : 'Сервіс відправки ще завантажується. Спробуйте ще раз або напишіть на info@lucasua.com';
      btn.parentNode.insertBefore(noEjs, btn.nextSibling);
      setTimeout(function () { noEjs.remove(); }, 6000);
      return;
    }

    submitted = true;
    btn.disabled = true;
    btn.innerHTML = isEn ? 'Sending…' : 'Надсилається…';

    window.emailjs.send('service_ocdfpq8', 'template_wz7w36q', {
      from_name: form.querySelector('[name="name"]').value.trim(),
      reply_to:  form.querySelector('[name="email"]').value.trim(),
      phone:     form.querySelector('[name="phone"]').value.trim(),
      message:   form.querySelector('[name="message"]').value.trim(),
      site:      window.location.hostname,
    }).then(function () {
      btn.innerHTML        = isEn ? '✓ Request sent' : '✓ Запит надіслано';
      btn.style.background = 'var(--orange)';
      btn.style.borderColor= 'var(--orange)';
      btn.style.color      = '#fff';
      form.reset();
      form.querySelectorAll('.field-err-msg').forEach(function (el) { el.remove(); });
      if (typeof gtag === 'function') {
        gtag('event', 'form_submit', { event_category: 'contact', event_label: 'lucas_contact_form' });
      }
    }).catch(function () {
      btn.disabled  = false;
      submitted     = false;
      btn.innerHTML = (isEn ? 'Send request' : 'Надіслати запит') + ' <span class="arrow"></span>';
      var errMsg = document.createElement('p');
      errMsg.style.cssText = 'color:rgba(255,92,31,.9);font-size:13px;margin-top:10px;font-family:var(--mono)';
      errMsg.textContent   = isEn
        ? 'Send error. Please try again or write to info@lucasua.com'
        : 'Помилка відправки. Спробуйте ще раз або напишіть на info@lucasua.com';
      btn.parentNode.insertBefore(errMsg, btn.nextSibling);
      setTimeout(function () { errMsg.remove(); }, 6000);
    });
  });
  } // end initForm

  if ('requestIdleCallback' in window) {
    requestIdleCallback(initForm, { timeout: 2000 });
  } else {
    setTimeout(initForm, 200);
  }
})();
</script>
