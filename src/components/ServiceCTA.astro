---
// ServiceCTA.astro
// Еталон: .sp-cta з other-services/index.html, audit/index.html та ін.
// Структура однакова на всіх сторінках послуг.
// Пунктуаційний знак наприкінці title (зазвичай «?») передається через prop.

interface Props {
  title: string;          // текст заголовка без фінального знаку
  titlePunct?: string;    // фінальний знак у .op (за замовчуванням «?»)
  text: string;           // параграф під заголовком
  href: string;           // href кнопки
  linkText: string;       // текст кнопки
}

const {
  title,
  titlePunct = '?',
  text,
  href,
  linkText,
} = Astro.props;
---

<section class="sp-cta">
  <div class="sp-cta-inner">
    <h2>{title}<span class="op">{titlePunct}</span></h2>
    <p>{text}</p>
    <div class="sp-cta-actions">
      <a class="btn cta-orange" href={href}>
        {linkText} <span class="arrow"></span>
      </a>
    </div>
  </div>
</section>
