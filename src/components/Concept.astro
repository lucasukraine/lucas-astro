---
const { lang = 'uk' } = Astro.props;

const t = {
  eyebrow: lang === 'en' ? 'Concept' : 'Концепція',
  taglineA: lang === 'en' ? 'Accounting at the core' : 'Аудит як основа',
  taglineB: lang === 'en' ? 'Technology where it matters.' : 'Технології - для перетворення вимог на рішення.',
  bodyIntro: lang === 'en'
    ? 'From financial statement audit to the delivery of complex regulatory and digital solutions — we combine financial expertise, tax methodology and technology so that financial, tax and digital challenges work as a unified system.'
    : 'Від аудиту фінансової звітності до впровадження складних регуляторних і цифрових рішень — ми поєднуємо фінансову експертизу, податкову методологію та технології, щоб фінансові, податкові та цифрові задачі працювали як єдина система.',
  bullet1: lang === 'en'
    ? 'finance work requires deeper understanding of data, systems, processes and technology risks;'
    : 'робота з фінансами потребує глибшого розуміння даних, систем, процесів і технологічних ризиків;',
  bullet2: lang === 'en'
    ? 'technology projects need developers who understand accounting, finance, tax and control.'
    : 'технологічний проєкт потребує розробників, які розуміють облік, фінанси, податки та контроль.',
  card1label: lang === 'en' ? 'Audit with technology perspective' : 'Аудит із розумінням систем',
  card1h3: lang === 'en' ? 'An auditor who sees the system behind the numbers' : 'Аудитор, що бачить систему за цифрами',
  card1p1: lang === 'en'
    ? 'Financial statements are not prepared in the final spreadsheet. They are produced by accounting systems, integrations, controls and data flows.'
    : 'Сучасна звітність формується не в останній таблиці, а всередині облікових систем, інтеграцій, контрольних процедур і потоків даних. Ми маємо кваліфікацію, щоб бачити, як інформація виникає, трансформується і потрапляє до фінансової звітності.',
  card1p2: lang === 'en'
    ? 'Our team is trained to understand how information originates, changes and flows into the financial statements.'
    : 'Це допомагає глибше розуміти ризики, точніше працювати з даними та бачити, як технології, автоматизація й якість процесів можуть впливати на фінансовий результат.',
  card2label: lang === 'en' ? 'Development aligned with accounting' : 'Розробка з аудиторською логікою',
  card2h3: lang === 'en' ? 'Solutions built on an audit approach' : 'Рішення на основі аудиторського підходу',
  card2p: lang === 'en'
    ? 'We build solutions for accounting, compliance and data work based on verifiability, controllability and transparency.'
    : 'Ми будуємо рішення для обліку, комплаєнсу та роботи з даними на основі перевірюваності, контрольованості та прозорості.',
  card3label: lang === 'en' ? 'Single financial context' : 'Єдиний фінансовий контекст',
  card3h3: lang === 'en' ? 'A shared language for finance and technology teams' : 'Бізнес, облік та IT — в єдиній системі вимог',
  card3p: lang === 'en'
    ? 'We align business processes, accounting methodology and IT solutions into a unified system of requirements — without losing meaning between finance and development.'
    : 'Ми узгоджуємо бізнес-процеси, облікову методологію та IT-рішення в єдину систему вимог — без втрати змісту між фінансами та розробкою.',
  credEyebrow: lang === 'en' ? 'Our approach' : 'Особливості підходу',
  cred1h4: lang === 'en' ? 'Conscious leadership' : 'Усвідомлене керування',
  cred1p: lang === 'en'
    ? 'Projects are led by specialists who understand the task, business context and management expectations.'
    : 'Проєкти ведуть фахівці, які розуміють зміст задачі, бізнес-контекст та очікування керівництва.',
  cred2h4: lang === 'en' ? 'Big 4 experience' : 'Досвід Big 4',
  cred2p: lang === 'en'
    ? 'Experience in complex audit and consulting projects across industries sets our standard.'
    : 'Досвід складних аудиторських та консалтингових проєктів у різних індустріях формує наш стандарт.',
  cred3h4: lang === 'en' ? 'Technology application' : 'Технологічна спроможність',
  cred3p: lang === 'en'
    ? 'The combination of our own accounting and development teams gives LUCAS technological capabilities unusual for the market.'
    : 'Комбінація власних команд з обліку та розробки дає LUCAS технологічні спроможності, нетипові для ринку.',
};
---

<section class="principles" id="concept">
  <!-- Gradient bleed from hero — visual continuity -->
  <div class="audit-bleed" aria-hidden="true"></div>

  <div class="container">

    <!-- Eyebrow + company description -->
    <div class="audit-intro reveal">
      <div class="eyebrow">{t.eyebrow}</div>
    </div>

    <!-- Theatrical tagline — section's visual climax -->
    <h2 class="audit-tagline reveal" data-d="1">
      <span class="audit-tagline-a">{t.taglineA}<span class="op">.</span></span>
      <span class="audit-tagline-b">{t.taglineB}</span>
    </h2>

    <!-- Body text with styled bullets -->
    <div class="audit-body reveal" data-d="2">
      <p style="text-align: center">{t.bodyIntro}</p>
    </div>

    <!-- Bento cards — asymmetric, 01 featured tall left -->
    <div class="audit-cards">

      <article class="audit-card has-corner reveal" data-d="1">
        <span class="audit-card-num" aria-hidden="true">01</span>
        <div class="audit-card-label">{t.card1label}</div>
        <h3>{t.card1h3}</h3>
        <p>{t.card1p1}</p>
        <p>{t.card1p2}</p>
      </article>

      <article class="audit-card reveal" data-d="2">
        <span class="audit-card-num" aria-hidden="true">02</span>
        <div class="audit-card-label">{t.card2label}</div>
        <h3>{t.card2h3}</h3>
        <p>{t.card2p}</p>
      </article>

      <article class="audit-card reveal" data-d="3">
        <span class="audit-card-num" aria-hidden="true">03</span>
        <div class="audit-card-label">{t.card3label}</div>
        <h3>{t.card3h3}</h3>
        <p>{t.card3p}</p>
      </article>

    </div><!-- /audit-cards -->

    <!-- Особливості підходу -->
    <div class="credentials reveal" data-d="4">
      <div class="credentials-eyebrow">
        <div class="eyebrow">{t.credEyebrow}</div>
        <span class="credentials-eyebrow-rule"></span>
      </div>
      <div class="cred">
        <div class="cred-roman">I · Lead</div>
        <h4>{t.cred1h4}</h4>
        <p>{t.cred1p}</p>
      </div>
      <div class="cred">
        <div class="cred-roman">II · Logic</div>
        <h4>{t.cred2h4}</h4>
        <p>{t.cred2p}</p>
      </div>
      <div class="cred">
        <div class="cred-roman">III · Build</div>
        <h4>{t.cred3h4}</h4>
        <p>{t.cred3p}</p>
      </div>
    </div><!-- /credentials -->

  </div><!-- /container -->
</section>
